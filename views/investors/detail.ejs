<%- include('../partials/header', { title: investor.name + ' ' + investor.surname }) %>
<%- include('../partials/navbar') %>

<main class="flex-grow-1 py-4">
  <div class="container">

    <!-- Üst navigasyon -->
    <div class="d-flex align-items-center mb-4">
      <a href="/investors" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
      </a>
      <nav aria-label="breadcrumb" class="flex-grow-1">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><a href="/investors" class="text-decoration-none">Yatırımcılar</a></li>
          <li class="breadcrumb-item active"><%= investor.name %> <%= investor.surname %></li>
        </ol>
      </nav>
      <div class="d-flex gap-2">
        <a href="/investors/<%= investor.id %>/edit" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-pencil me-1"></i>Düzenle
        </a>
        <a href="/investors/<%= investor.id %>/notes/add" class="btn btn-primary btn-sm fw-semibold">
          <i class="bi bi-plus-lg me-1"></i>Not Ekle
        </a>
      </div>
    </div>

    <!-- Flash mesajı -->
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> alert-dismissible border-0" role="alert">
        <i class="bi bi-check-circle me-2"></i><%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Yatırımcı bilgi kartı -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <div class="row align-items-center">
          <div class="col-auto">
            <div class="investor-avatar">
              <%= investor.name.charAt(0).toUpperCase() %><%= investor.surname.charAt(0).toUpperCase() %>
            </div>
          </div>
          <div class="col">
            <h4 class="fw-bold mb-1"><%= investor.name %> <%= investor.surname %></h4>
            <div class="d-flex flex-wrap gap-3 text-muted">
              <% if (investor.phone) { %>
                <span><i class="bi bi-telephone me-1"></i>
                  <a href="tel:<%= investor.phone %>" class="text-decoration-none text-muted"><%= investor.phone %></a>
                </span>
              <% } %>
              <% if (investor.email) { %>
                <span><i class="bi bi-envelope me-1"></i>
                  <a href="mailto:<%= investor.email %>" class="text-decoration-none text-muted"><%= investor.email %></a>
                </span>
              <% } %>
              <span><i class="bi bi-person me-1"></i>Ekleyen: <%= investor.creator_name || 'Bilinmiyor' %></span>
              <span><i class="bi bi-calendar3 me-1"></i><%= new Date(investor.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            </div>
          </div>
          <div class="col-auto text-end">
            <div class="fw-bold fs-2 text-primary"><%= notes.length %></div>
            <small class="text-muted">görüşme adımı</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Görüşme Notları -->
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h5 class="fw-bold mb-0">
        <i class="bi bi-chat-left-text me-2 text-primary"></i>Görüşme Notları
      </h5>
      <a href="/investors/<%= investor.id %>/notes/add" class="btn btn-primary btn-sm fw-semibold">
        <i class="bi bi-plus-lg me-1"></i>Yeni Adım Ekle
      </a>
    </div>

    <% if (notes.length === 0) { %>
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
          <i class="bi bi-chat-left text-muted" style="font-size: 2.5rem;"></i>
          <p class="text-muted mt-3 mb-3">Henüz not eklenmemiş.</p>
          <a href="/investors/<%= investor.id %>/notes/add" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>İlk Notu Ekle
          </a>
        </div>
      </div>
    <% } else { %>
      <!-- Timeline -->
      <div class="timeline">
        <% notes.forEach((note, idx) => {
          const colors = ['primary', 'success', 'warning', 'info', 'danger', 'secondary'];
          const color = colors[idx % colors.length];
        %>
        <div class="timeline-item">
          <div class="timeline-badge bg-<%= color %>">
            <%= note.step_number %>
          </div>
          <div class="timeline-content">
            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
              <div>
                <% if (note.title) { %>
                  <h6 class="fw-bold mb-1"><%= note.title %></h6>
                <% } %>
                <div class="d-flex flex-wrap gap-2 text-muted small">
                  <span><i class="bi bi-hash"></i>Adım <%= note.step_number %></span>
                  <% if (note.meeting_date) { %>
                    <span><i class="bi bi-calendar-event me-1"></i><%= new Date(note.meeting_date + 'T00:00:00').toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                  <% } %>
                  <span><i class="bi bi-person me-1"></i><%= note.added_by_name || 'Bilinmiyor' %></span>
                  <span><i class="bi bi-clock me-1"></i><%= new Date(note.created_at).toLocaleDateString('tr-TR') %></span>
                  <% if (note.updated_at && note.updated_at !== note.created_at) { %>
                    <span class="fst-italic">(güncellendi)</span>
                  <% } %>
                </div>
              </div>
              <div class="d-flex gap-1 flex-shrink-0">
                <a href="/investors/<%= investor.id %>/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary py-0 px-2">
                  <i class="bi bi-pencil"></i>
                </a>
                <form method="POST" action="/investors/<%= investor.id %>/notes/<%= note.id %>/delete" class="d-inline" onsubmit="return confirm('Bu not silinecek. Emin misiniz?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </div>
            <p class="mb-0 text-dark note-content"><%= note.content %></p>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
