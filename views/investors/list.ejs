<%- include('../partials/header', { title: 'Yatırımcılar' }) %>
<%- include('../partials/navbar', { activePage: 'investors' }) %>

<main class="flex-grow-1 py-4">
  <div class="container">

    <!-- Başlık ve arama -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
      <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-people-fill me-2 text-primary"></i>Yatırımcılar</h4>
        <small class="text-muted"><%= investors.length %> kayıt</small>
      </div>
      <div class="d-flex gap-2">
        <form method="GET" action="/investors" class="d-flex gap-2">
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input
              type="text"
              class="form-control"
              name="search"
              value="<%= search %>"
              placeholder="Ad, soyad, telefon ara..."
              style="min-width: 220px;"
            >
            <% if (search) { %>
              <a href="/investors" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i>
              </a>
            <% } %>
          </div>
          <button type="submit" class="btn btn-outline-primary">Ara</button>
        </form>
        <a href="/investors/add" class="btn btn-primary fw-semibold">
          <i class="bi bi-person-plus me-1"></i>Yeni Ekle
        </a>
      </div>
    </div>

    <!-- Flash mesajı -->
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> alert-dismissible border-0 shadow-sm" role="alert">
        <i class="bi bi-<%= flash.type === 'success' ? 'check-circle' : 'exclamation-circle' %> me-2"></i>
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Tablo -->
    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <% if (investors.length === 0) { %>
          <div class="text-center py-5">
            <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-3 mb-2">
              <% if (search) { %>
                "<%= search %>" için sonuç bulunamadı.
              <% } else { %>
                Henüz yatırımcı eklenmemiş.
              <% } %>
            </p>
            <% if (!search) { %>
              <a href="/investors/add" class="btn btn-primary btn-sm">
                <i class="bi bi-person-plus me-1"></i>İlk Yatırımcıyı Ekle
              </a>
            <% } %>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">#</th>
                  <th>Ad Soyad</th>
                  <th>Telefon</th>
                  <th>E-posta</th>
                  <th class="text-center">Görüşme Adımı</th>
                  <th>Ekleyen</th>
                  <th>Tarih</th>
                  <th class="text-end pe-4">İşlem</th>
                </tr>
              </thead>
              <tbody>
                <% investors.forEach((inv, i) => { %>
                  <tr>
                    <td class="ps-4 text-muted"><small><%= i + 1 %></small></td>
                    <td>
                      <a href="/investors/<%= inv.id %>" class="text-decoration-none fw-semibold text-dark">
                        <%= inv.name %> <%= inv.surname %>
                      </a>
                    </td>
                    <td>
                      <% if (inv.phone) { %>
                        <a href="tel:<%= inv.phone %>" class="text-decoration-none text-muted">
                          <i class="bi bi-telephone me-1"></i><%= inv.phone %>
                        </a>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (inv.email) { %>
                        <small class="text-muted"><%= inv.email %></small>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td class="text-center">
                      <% if (inv.note_count > 0) { %>
                        <%
                          let badgeClass = 'bg-primary';
                          let statusLabel = '';
                          if (inv.latest_status === 'cevapsiz') {
                            badgeClass = 'bg-danger';
                            statusLabel = ' · Cevapsız';
                          } else if (inv.latest_status === 'aktif') {
                            badgeClass = 'bg-success';
                            statusLabel = ' · Aktif';
                          } else if (inv.latest_status === 'daha_sonra') {
                            badgeClass = 'bg-warning text-dark';
                            statusLabel = ' · Daha Sonra';
                          }
                        %>
                        <span class="badge <%= badgeClass %> rounded-pill">
                          <i class="bi bi-chat-left-text me-1"></i><%= inv.note_count %> not<%= statusLabel %>
                        </span>
                      <% } else { %>
                        <span class="badge bg-light text-muted">Not yok</span>
                      <% } %>
                    </td>
                    <td><small class="text-muted"><%= inv.creator_name || '—' %></small></td>
                    <td>
                      <small class="text-muted">
                        <%= new Date(inv.created_at).toLocaleDateString('tr-TR') %>
                      </small>
                    </td>
                    <td class="text-end pe-4">
                      <div class="d-flex gap-1 justify-content-end">
                        <a href="/investors/<%= inv.id %>" class="btn btn-sm btn-outline-primary" title="Detay">
                          <i class="bi bi-eye"></i>
                        </a>
                        <a href="/investors/<%= inv.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Düzenle">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST" action="/investors/<%= inv.id %>/delete" class="d-inline" onsubmit="return confirm('<%= inv.name %> <%= inv.surname %> ve tüm notları silinecek. Emin misiniz?')">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
