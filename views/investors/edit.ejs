<%- include('../partials/header', { title: 'Yatırımcı Düzenle' }) %>
<%- include('../partials/navbar') %>

<main class="flex-grow-1 py-4">
  <div class="container" style="max-width: 620px;">

    <div class="d-flex align-items-center mb-4">
      <a href="/investors/<%= investor.id %>" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
      </a>
      <div>
        <h4 class="fw-bold mb-0">Yatırımcı Düzenle</h4>
        <small class="text-muted"><%= investor.name %> <%= investor.surname %></small>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <% if (error) { %>
          <div class="alert alert-danger border-0" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
          </div>
        <% } %>

        <form method="POST" action="/investors/<%= investor.id %>/edit">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="name" class="form-label fw-semibold">Ad <span class="text-danger">*</span></label>
              <input
                type="text"
                class="form-control"
                id="name"
                name="name"
                required
                value="<%= investor.name %>"
                maxlength="100"
              >
            </div>
            <div class="col-md-6">
              <label for="surname" class="form-label fw-semibold">Soyad <span class="text-danger">*</span></label>
              <input
                type="text"
                class="form-control"
                id="surname"
                name="surname"
                required
                value="<%= investor.surname %>"
                maxlength="100"
              >
            </div>
            <div class="col-md-6">
              <label for="phone" class="form-label fw-semibold">Telefon</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                <input
                  type="text"
                  class="form-control"
                  id="phone"
                  name="phone"
                  value="<%= investor.phone || '' %>"
                  maxlength="50"
                >
              </div>
            </div>
            <div class="col-md-6">
              <label for="email" class="form-label fw-semibold">E-posta</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <input
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  value="<%= investor.email || '' %>"
                  maxlength="100"
                >
              </div>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary fw-semibold px-4">
              <i class="bi bi-check-lg me-2"></i>Güncelle
            </button>
            <a href="/investors/<%= investor.id %>" class="btn btn-outline-secondary px-4">İptal</a>
          </div>
        </form>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
