<%- include('../partials/header', { title: 'Not Düzenle' }) %>
<%- include('../partials/navbar') %>

<main class="flex-grow-1 py-4">
  <div class="container" style="max-width: 680px;">

    <div class="d-flex align-items-center mb-4">
      <a href="/investors/<%= investor.id %>" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
      </a>
      <div>
        <h4 class="fw-bold mb-0">Görüşme Notu Düzenle</h4>
        <small class="text-muted">
          <i class="bi bi-person me-1"></i><%= investor.name %> <%= investor.surname %> — Adım <%= note.step_number %>
        </small>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <% if (error) { %>
          <div class="alert alert-danger border-0" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
          </div>
        <% } %>

        <form method="POST" action="/investors/<%= investor.id %>/notes/<%= note.id %>/edit">
          <div class="row g-3">
            <div class="col-md-4">
              <label for="step_number" class="form-label fw-semibold">Adım No <span class="text-danger">*</span></label>
              <input
                type="number"
                class="form-control"
                id="step_number"
                name="step_number"
                value="<%= note.step_number %>"
                min="1"
                required
              >
            </div>
            <div class="col-md-8">
              <label for="meeting_date" class="form-label fw-semibold">Görüşme Tarihi</label>
              <input
                type="date"
                class="form-control"
                id="meeting_date"
                name="meeting_date"
                value="<%= note.meeting_date ? new Date(note.meeting_date).toISOString().split('T')[0] : '' %>"
              >
            </div>
            <div class="col-12">
              <label for="title" class="form-label fw-semibold">Başlık <span class="text-muted fw-normal">(isteğe bağlı)</span></label>
              <input
                type="text"
                class="form-control"
                id="title"
                name="title"
                value="<%= note.title || '' %>"
                placeholder="Örn: İlk Görüşme, Sunum, Sözleşme..."
                maxlength="200"
              >
            </div>
            <div class="col-12">
              <label for="content" class="form-label fw-semibold">Not İçeriği <span class="text-danger">*</span></label>
              <textarea
                class="form-control"
                id="content"
                name="content"
                rows="8"
                required
              ><%= note.content %></textarea>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Durum <span class="text-muted fw-normal">(isteğe bağlı)</span></label>
              <input type="hidden" name="status" id="statusInput" value="<%= note.status || '' %>">
              <div class="d-flex gap-2 flex-wrap" id="statusButtons">
                <button type="button" class="btn <%= note.status === 'cevapsiz' ? 'btn-danger' : 'btn-outline-danger' %> status-btn" data-value="cevapsiz">
                  <i class="bi bi-telephone-x me-1"></i>Cevapsız
                </button>
                <button type="button" class="btn <%= note.status === 'aktif' ? 'btn-success' : 'btn-outline-success' %> status-btn" data-value="aktif">
                  <i class="bi bi-check-circle me-1"></i>Aktif Hesap
                </button>
                <button type="button" class="btn <%= note.status === 'daha_sonra' ? 'btn-warning' : 'btn-outline-warning' %> status-btn" data-value="daha_sonra">
                  <i class="bi bi-clock me-1"></i>Daha Sonra Görüşülecek
                </button>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary fw-semibold px-4">
              <i class="bi bi-check-lg me-2"></i>Güncelle
            </button>
            <a href="/investors/<%= investor.id %>" class="btn btn-outline-secondary px-4">İptal</a>
          </div>
        </form>
      </div>
    </div>

  </div>
</main>

<script>
  const statusConfig = {
    'cevapsiz':  { active: 'btn-danger',  outline: 'btn-outline-danger' },
    'aktif':     { active: 'btn-success', outline: 'btn-outline-success' },
    'daha_sonra':{ active: 'btn-warning', outline: 'btn-outline-warning' }
  };
  document.querySelectorAll('.status-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const val = this.dataset.value;
      const input = document.getElementById('statusInput');
      if (input.value === val) {
        input.value = '';
        this.classList.remove(statusConfig[val].active);
        this.classList.add(statusConfig[val].outline);
      } else {
        document.querySelectorAll('.status-btn').forEach(b => {
          const bVal = b.dataset.value;
          b.classList.remove(statusConfig[bVal].active);
          b.classList.add(statusConfig[bVal].outline);
        });
        input.value = val;
        this.classList.remove(statusConfig[val].outline);
        this.classList.add(statusConfig[val].active);
      }
    });
  });
</script>

<%- include('../partials/footer') %>
